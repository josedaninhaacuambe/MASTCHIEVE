generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  role          String    // ADMIN | INSTRUCTOR | STUDENT | PARENT
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  refreshToken  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  admin         Admin?
  instructor    Instructor?
  student       Student?
  parent        Parent?
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─── Admin ───────────────────────────────────────────────────────────────────

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  firstName   String
  lastName    String
  phone       String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ─── Instructor ───────────────────────────────────────────────────────────────

model Instructor {
  id              String    @id @default(uuid())
  userId          String    @unique
  firstName       String
  lastName        String
  phone           String?
  avatarUrl       String?
  specializations String    @default("[]")
  bio             String?
  isActive        Boolean   @default(true)
  hireDate        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes         Class[]
  attendances     Attendance[]
  feedbacks       Feedback[]
  trainingPlans   TrainingPlan[]

  @@index([isActive])
  @@map("instructors")
}

// ─── Student ─────────────────────────────────────────────────────────────────

model Student {
  id               String    @id @default(uuid())
  userId           String    @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String    @default("OTHER")
  phone            String?
  avatarUrl        String?
  medicalNotes     String?
  emergencyContact String?
  emergencyPhone   String?
  enrollmentDate   DateTime  @default(now())
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parents          StudentParent[]
  enrollments      Enrollment[]
  attendances      Attendance[]
  feedbacks        Feedback[]
  progressRecords  Progress[]
  trainingPlans    TrainingPlan[]
  payments         Payment[]
  monthlyFees      MonthlyFee[]
  documents        Document[]

  @@index([isActive])
  @@map("students")
}

// ─── Parent ───────────────────────────────────────────────────────────────────

model Parent {
  id           String    @id @default(uuid())
  userId       String    @unique
  firstName    String
  lastName     String
  phone        String
  relationship String    @default("Parent")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  children     StudentParent[]

  @@map("parents")
}

model StudentParent {
  studentId String
  parentId  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
  @@map("student_parents")
}

// ─── Classes ─────────────────────────────────────────────────────────────────

model Class {
  id           String   @id @default(uuid())
  name         String
  description  String?
  level        String   @default("BEGINNER")
  status       String   @default("ACTIVE")
  maxStudents  Int      @default(15)
  poolLane     String?
  schedules    String   @default("[]")
  instructorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instructor   Instructor  @relation(fields: [instructorId], references: [id])
  enrollments  Enrollment[]
  sessions     ClassSession[]

  @@index([status])
  @@index([instructorId])
  @@map("classes")
}

model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  classId    String
  enrolledAt DateTime @default(now())
  isActive   Boolean  @default(true)
  notes      String?

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@index([isActive])
  @@map("enrollments")
}

// ─── Class Sessions & Attendance ─────────────────────────────────────────────

model ClassSession {
  id          String   @id @default(uuid())
  classId     String
  sessionDate DateTime
  startTime   String
  endTime     String
  notes       String?
  topic       String?
  createdAt   DateTime @default(now())

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  feedbacks   Feedback[]

  @@index([classId])
  @@map("class_sessions")
}

model Attendance {
  id           String   @id @default(uuid())
  sessionId    String
  studentId    String
  instructorId String
  status       String   @default("PRESENT")
  notes        String?
  markedAt     DateTime @default(now())

  session      ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor   Instructor   @relation(fields: [instructorId], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendances")
}

// ─── Performance & Feedback ──────────────────────────────────────────────────

model PerformanceRecord {
  id              String   @id @default(uuid())
  studentId       String
  sessionId       String?
  instructorId    String?
  technique       Int?
  stamina         Int?
  speed           Int?
  coordination    Int?
  breathing       Int?
  turns           Int?
  startDive       Int?
  overallScore    Float?
  instructorNotes String?
  rawData         String?
  recordedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  feedback        Feedback?

  @@index([studentId])
  @@map("performance_records")
}

model Feedback {
  id                  String   @id @default(uuid())
  studentId           String
  sessionId           String?
  instructorId        String?
  performanceRecordId String?  @unique
  status              String   @default("PENDING")
  aiGeneratedText     String?
  instructorNotes     String?
  finalText           String?
  recommendedLessons  String   @default("[]")
  interactiveExercises String  @default("[]")
  sentToParentAt      DateTime?
  sentToStudentAt     DateTime?
  aiModel             String?
  aiTokensUsed        Int?
  aiConfidenceScore   Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  student             Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session             ClassSession?     @relation(fields: [sessionId], references: [id])
  instructor          Instructor?       @relation(fields: [instructorId], references: [id])
  performanceRecord   PerformanceRecord? @relation(fields: [performanceRecordId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("feedbacks")
}

// ─── Progress & Modules ──────────────────────────────────────────────────────

model SwimmingModule {
  id          String   @id @default(uuid())
  name        String
  description String?
  level       String   @default("BEGINNER")
  order       Int
  skills      String   @default("[]")
  videos      String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  progress    Progress[]

  @@map("swimming_modules")
}

model Progress {
  id          String    @id @default(uuid())
  studentId   String
  moduleId    String
  status      String    @default("NOT_STARTED")
  startedAt   DateTime?
  completedAt DateTime?
  score       Float?
  notes       String?
  updatedAt   DateTime  @updatedAt

  student     Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module      SwimmingModule @relation(fields: [moduleId], references: [id])

  @@unique([studentId, moduleId])
  @@index([studentId])
  @@map("progress")
}

// ─── Training Plans ───────────────────────────────────────────────────────────

model TrainingPlan {
  id           String    @id @default(uuid())
  studentId    String
  instructorId String?
  title        String
  description  String?
  objectives   String    @default("[]")
  exercises    String    @default("[]")
  aiGenerated  Boolean   @default(false)
  isActive     Boolean   @default(true)
  validFrom    DateTime
  validUntil   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor   Instructor? @relation(fields: [instructorId], references: [id])

  @@index([studentId])
  @@map("training_plans")
}

// ─── Financial ───────────────────────────────────────────────────────────────

model MonthlyFee {
  id          String   @id @default(uuid())
  studentId   String
  month       Int
  year        Int
  amount      Float
  dueDate     DateTime
  description String?
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payment     Payment?

  @@unique([studentId, month, year])
  @@index([studentId])
  @@map("monthly_fees")
}

model Payment {
  id            String    @id @default(uuid())
  studentId     String
  monthlyFeeId  String?   @unique
  amount        Float
  method        String    @default("CASH")
  status        String    @default("PENDING")
  reference     String?
  receiptNumber String?   @unique
  notes         String?
  paidAt        DateTime?
  dueDate       DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  monthlyFee    MonthlyFee? @relation(fields: [monthlyFeeId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("payments")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("INFO")
  title     String
  body      String
  data      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id         String   @id @default(uuid())
  studentId  String
  name       String
  type       String
  url        String
  size       Int?
  uploadedAt DateTime @default(now())

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("documents")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValues String?
  newValues String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("audit_logs")
}

// ─── KPI Snapshots ───────────────────────────────────────────────────────────

model KpiSnapshot {
  id                    String   @id @default(uuid())
  snapshotDate          DateTime @default(now())
  totalStudents         Int
  activeStudents        Int
  totalInstructors      Int
  totalClasses          Int
  attendanceRate        Float
  avgFeedbackScore      Float?
  npsScore              Float?
  instructorAdoptionRate Float?
  overduePayments       Int
  monthlyRevenue        Float?
  createdAt             DateTime @default(now())

  @@map("kpi_snapshots")
}
